# Server
PORT=9200
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=your_password_here
DB_NAME=your_db_name

# JWT
JWT_SECRET=your_jwt_secret_here_make_it_long_and_random

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Brevo / SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password_here
BREVO_API_KEY=your_brevo_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_REDIRECT_URL=https://rentulo.ng/tenant/locked-house
PAYSTACK_FAILURE_URL=https://rentulo.ng/tenant/locked-house
PAYSTACK_LOCK_CALLBACK_URL=
PAYSTACK_CALLBACK_URL=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=https://rentulo.ng,http://localhost:3000

# OpenAI (AI Support Chat)
OPENAI_API_KEY=sk-your_openai_api_key_here
